# ============================================================
# Neon Database
# ============================================================
# Neon コンソール > Connection Details から取得
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ============================================================
# Anthropic (Claude AI)
# ============================================================
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# X (Twitter) API
# ============================================================
# developer.twitter.com > Project/App > Keys and Tokens
# Consumer Keys
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here

# アカウントごとのアクセストークンは DB の accounts テーブルで管理
# X_ACCESS_TOKEN と X_ACCESS_SECRET は accounts テーブルに保存する

# ============================================================
# Cron 認証シークレット
# ============================================================
# Vercel Cron が /api/cron/post を叩く際の Bearer トークン
# Vercel 環境変数にも同じ値を設定すること
CRON_SECRET=your_random_secret_here

# ============================================================
# NewsAPI
# ============================================================
# https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here
