# ============================================================
# Neon Database
# ============================================================
# Neon コンソール > Connection Details から取得
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ============================================================
# Anthropic (Claude AI)
# ============================================================
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# OpenAI (画像生成)
# ============================================================
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ============================================================
# X (Twitter) API
# ============================================================
# developer.twitter.com > Project/App > Keys and Tokens
# Consumer Keys
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here

# アカウントごとのアクセストークンは DB の accounts テーブルで管理
# X_ACCESS_TOKEN と X_ACCESS_SECRET は accounts テーブルに保存する

# ============================================================
# Cron 認証シークレット
# ============================================================
# Vercel Cron が /api/cron/post を叩く際の Bearer トークン
# Vercel 環境変数にも同じ値を設定すること
CRON_SECRET=your_random_secret_here

# ============================================================
# ニュースソース設定
# ============================================================
# NEWS_SOURCE=rss      → Yahoo!ニュースRSS（デフォルト・無料・制限なし）
# NEWS_SOURCE=newsapi  → NewsAPI（APIキー必要・本番環境は有料プラン必須）
NEWS_SOURCE=rss

# NewsAPI を使う場合のみ設定（https://newsapi.org/register）
NEWS_API_KEY=your_newsapi_key_here

# ============================================================
# エンゲージメント設定
# ============================================================
# いいね・リポスト・リプライ対象のキーワード（カンマ区切り）
ENGAGE_KEYWORDS=AI,ChatGPT,副業,節約,転職

# 技術情報発信アカウント（2つ目）
TECH_ACCOUNT_ACCESS_TOKEN=
TECH_ACCOUNT_ACCESS_SECRET=
TECH_SOURCE_ACCOUNTS=Naokyyy3
